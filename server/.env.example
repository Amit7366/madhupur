# MongoDB (use your Atlas URI; do not commit real credentials)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/pineapplecity?retryWrites=true&w=majority

PORT=4000

# Must include every origin where the frontend runs (scheme + host + port). Add production URLs.
# Example: http://localhost:3000,http://127.0.0.1:3000,https://your-domain.com
CLIENT_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Cloudinary (required when complaint submissions include photos)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
