# MongoDB (use your Atlas URI; do not commit real credentials)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/pineapplecity?retryWrites=true&w=majority

PORT=4000

# Must include every origin where the Next app runs (scheme + host + port). Add production URLs.
# Example: http://localhost:3000,http://127.0.0.1:3000,https://your-domain.com
CLIENT_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Vercel (Project → Settings → Environment Variables) ---
# Set the same keys: MONGODB_URI, CLIENT_ORIGINS (include https://your-frontend.vercel.app).
# PORT is ignored on Vercel. Allow 0.0.0.0/0 on MongoDB Atlas Network Access for serverless egress.
